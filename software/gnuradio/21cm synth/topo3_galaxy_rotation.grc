- name: note_1
  id: note
  parameters:
    alias: ''
    comment: ''
    note: Per-branch Multiply Const blocks are added after each LPF to normalize the
      synthetic component strengths after spectral shaping. Since each branch has
      a different filter bandwidth, the output power is not set only by the source
      amplitude. These gains make the relative strengths intentional and repeatable
      instead of being implicitly determined by filter width.
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [856, 172.0]
    rotation: 0
    state: enabled
