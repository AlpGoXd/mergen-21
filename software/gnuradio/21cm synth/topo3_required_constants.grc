options:
  parameters:
    author: OpenAI
    catch_exceptions: 'True'
    category: '[GRC Hier Blocks]'
    cmake_opt: ''
    comment: Simulation-only branch RMS measurement and required gain calculator for
      the Topo 3 hydrogen-line synthesizer. Uses RMS so required Multiply Const =
      target_rms / measured_rms.
    copyright: ''
    description: Measure raw branch RMS after LPFs and directly show required Multiply
      Const values.
    gen_cmake: 'On'
    gen_linking: dynamic
    generate_options: qt_gui
    hier_block_src_path: '.:'
    id: topo3_required_constants
    max_nouts: '0'
    output_language: python
    placement: (0,0)
    qt_qss_theme: ''
    realtime_scheduling: ''
    run: 'True'
    run_command: '{python} -u {filename}'
    run_options: prompt
    sizing_mode: fixed
    thread_safe_setters: ''
    title: Topo 3 Required Constants Meter
    window_size: ''
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [8, 8]
    rotation: 0
    state: enabled

blocks:
- name: fft_size
  id: variable
  parameters:
    comment: ''
    value: '4096'
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [24, 72]
    rotation: 0
    state: enabled
